@startuml
skinparam handwritten false
skinparam monochrome false
skinparam packageStyle rect
skinparam shadowing false
skinparam defaultFontName "Courier New"
skinparam ranksep 20
skinparam dpi 150

skinparam activity {
  BackgroundColor<<RAW>> #E0F7FA
  BorderColor<<RAW>> #00838F
  BackgroundColor<<Transition>> #FFFDE7
  BorderColor<<Transition>> #FBC02D
  BackgroundColor<<RGB>> #FFEBEE
  BorderColor<<RGB>> #C62828
  BackgroundColor<<NonLinear>> #F3E5F5
  BorderColor<<NonLinear>> #6A1B9A
}

title CUDA ISP Pipeline Flowchart

start

partition "RAW Domain (Bayer CFA)" {
    :RawUnpack<<RAW>>;
    note right: Unpacks packed RAW\n(e.g., MIPI10 -> uint16)
    
    :BlackLevelCorrection<<RAW>>;
    note right: Baseline subtraction\n(clamp to 0)
    
    :DeadPixelCorrection<<RAW>>;
    note right: Removes hot/dead pixels\nusing homogeneous neighbors
    
    :LensShadingCorrection<<RAW>>;
    note right: Compensates lens vignetting\nusing grid LUT
    
    :WhiteBalance<<RAW>>;
    note right: Applies per-channel gains\n(Manual or Auto GrayWorld)
}

partition "Transition" {
    :Demosaic (Optimized)<<Transition>>;
    note right: Bilinear interpolation\n(Bayer -> Linear RGB)
}

partition "Linear RGB Domain" {
    :ColorCorrectionMatrix<<RGB>>;
    note right: 3x3 matrix conversion\n(Sensor RGB -> sRGB)
}

partition "Non-Linear & Output Domain" {
    :GammaCorrection (sRGB)<<NonLinear>>;
    note right: Non-linear gamma curve\n(float mapping)
    
    :OutputPack<<NonLinear>>;
    note right: Scales and clamps\n(float -> uint8 RGB)
}

stop
@enduml
